# Copy to .env and fill in values

# --- Local Postgres (development) ---
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pos?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/pos?schema=public"

# --- Supabase (production / staging) ---
# DATABASE_URL is used at runtime — must be the pooled "Transaction" URL (port 6543) for serverless.
# DIRECT_URL is used by `prisma migrate` only — must be the direct URL (port 5432).
# Both URLs need ?sslmode=require for Supabase.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"

JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
PORT=4000
CORS_ORIGIN="http://localhost:5173"
