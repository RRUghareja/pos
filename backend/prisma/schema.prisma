generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  WORKER
  CUSTOMER
}

enum SalaryType {
  HOURLY
  DAILY
}

enum WorkerStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELIVERED
  CANCELLED
}

enum InventoryType {
  RAW_MATERIAL
  KITCHEN_EQUIPMENT
  OTHER
}

enum OrderMessageType {
  CHAT
  COMPLAINT
  SUGGESTION
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  phone        String?   @unique
  passwordHash String
  name         String
  role         Role
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  worker       Worker?
  customer     Customer?
  orders       Order[]   @relation("OrderCreatedBy")
  orderMessages OrderMessage[]
}

model Worker {
  id          String        @id @default(cuid())
  userId      String        @unique
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  address     String?
  joiningDate DateTime      @default(now())
  salaryType  SalaryType    @default(HOURLY)
  salaryRate  Decimal       @default(0) @db.Decimal(10, 2)
  department  String?
  status      WorkerStatus  @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  attendances    Attendance[]
  orderAssignments OrderWorker[]
}

model Attendance {
  id          String    @id @default(cuid())
  workerId    String
  worker      Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  checkIn     DateTime
  checkOut    DateTime?
  breakMins   Int       @default(0)
  notes       String?
  createdAt   DateTime  @default(now())

  @@index([workerId, checkIn])
}

model Customer {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]  @relation("OrderCustomer")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  category    String?
  imageUrl    String?
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems     OrderItem[]
  inventory      InventoryItem?
  cuisineRecipes CuisineProduct[]
}

model Cuisine {
  id            String   @id @default(cuid())
  name          String
  description   String?
  category      String?
  pricePerPlate Decimal  @default(0) @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  recipe     CuisineProduct[]
  orderLines OrderCuisine[]
}

model CuisineProduct {
  id        String  @id @default(cuid())
  cuisineId String
  productId String
  quantity  Decimal @default(1) @db.Decimal(10, 2)
  unit      String?
  cuisine   Cuisine @relation(fields: [cuisineId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@unique([cuisineId, productId])
  @@index([productId])
}

model OrderCuisine {
  id        String  @id @default(cuid())
  orderId   String
  cuisineId String
  plates    Int
  unitPrice Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cuisine   Cuisine @relation(fields: [cuisineId], references: [id])

  @@unique([orderId, cuisineId])
  @@index([cuisineId])
}

model InventoryItem {
  id            String   @id @default(cuid())
  productId     String?  @unique
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name          String
  category      String?
  quantity      Int      @default(0)
  unit          String   @default("piece")
  minStockLevel Int      @default(0)
  supplierName  String?
  costPrice     Decimal  @default(0) @db.Decimal(10, 2)
  sellingPrice  Decimal  @default(0) @db.Decimal(10, 2)
  type          InventoryType @default(OTHER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderUsage    OrderInventoryItem[]
}

model Order {
  id               String       @id @default(cuid())
  orderNumber      String       @unique
  customerId       String?
  customer         Customer?    @relation("OrderCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  createdById      String
  createdBy        User         @relation("OrderCreatedBy", fields: [createdById], references: [id])
  status           OrderStatus  @default(PENDING)
  total            Decimal      @default(0) @db.Decimal(10, 2)
  notes            String?
  location         String?
  scheduledFor    DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  items            OrderItem[]
  cuisines         OrderCuisine[]
  workers          OrderWorker[]
  inventoryUsage   OrderInventoryItem[]
  messages         OrderMessage[]
}

model OrderMessage {
  id        String           @id @default(cuid())
  orderId   String
  authorId  String
  type      OrderMessageType @default(CHAT)
  body      String
  createdAt DateTime         @default(now())

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([authorId])
}

model OrderWorker {
  id        String   @id @default(cuid())
  orderId   String
  workerId  String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([orderId, workerId])
  @@index([workerId])
}

model OrderInventoryItem {
  id              String        @id @default(cuid())
  orderId         String
  inventoryItemId String
  quantity        Int
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@unique([orderId, inventoryItemId])
  @@index([inventoryItemId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
}
